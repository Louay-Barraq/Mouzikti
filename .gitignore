# Virtual Environment
# This is the "toolbox" we created; we don't want this on GitHub
.venv/
venv/
env/
ENV/

# Python Bytecode & Cache
# These are generated by Python to make code run faster; no need to track them
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.pylint.d/

# macOS System Files
# These are hidden files macOS creates to store folder settings
.DS_Store
.AppleDouble
.LSOverride

# VS Code Settings
# Optional: keep your personal editor settings out of the repo
.vscode/

# Project Specific
# If your 'outputs' folder contains generated music/logs, you might want to ignore it
outputs/
config.json
directory_summary.txt
gen.py
docs/
output/
default.sf2
reports/